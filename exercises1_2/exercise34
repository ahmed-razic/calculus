#Define a function
f(x) = 0.5*(x + 1) + 5
g(x) = 0.5*(x + 1 - 1) + 5 - 5

set terminal qt 0
set grid
set xtics 1
set ytics 1
set size ratio 1
set xrange [-10:10]
set yrange [-10:10]
set arrow nohead from -4,0 to 4,0
set arrow nohead from 0,-4 to 0,4
plot f(x) with lines, g(x) with lines

pause -1
#EOF

