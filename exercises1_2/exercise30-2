f(x) = (x**(1.0/3.0))**2
g(x) = (x - 1)**(1.0/3.0) - 1

set terminal qt 0
set grid
set xtics 1
set ytics 1
set size ratio 1
set xrange [-3:3]
set yrange [-3:3]
