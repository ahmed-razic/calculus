#Define a function
f(x) = sqrt(x)
g(x) = -sqrt(x)
h(x) = -sqrt(x) + 1

set terminal qt 0
set grid
set xtics 1
set ytics 1
set size ratio 1
set xrange [0:5]
set yrange [-3:3]
set arrow nohead from -5,0 to 5,0
set arrow nohead from 0,-5 to 0,5
plot f(x) with lines, g(x) with lines, h(x) with lines lw 3

pause -1
#EOF

