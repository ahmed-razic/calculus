#Define a function
f(x) = sqrt(x - 1) +1

# set terminal qt 0

set terminal pngcairo size 600,400
set output "transparent.png"

set grid
set xtics 1
set ytics 1
set size ratio 1
set xrange [0:5]
set yrange [-3:3]
# set arrow nohead from -5,0 to 5,0
# set arrow nohead from 0,-5 to 0,5
plot [0:5] 0 dt 3, [1:5] f(x) with lines

pause -1
#EOF

