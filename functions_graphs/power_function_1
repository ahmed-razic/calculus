# power functions y = x**2k

f1(x) = x**2
f2(x) = x**4
f3(x) = x**6
f4(x) = x**8

set xrange [-3:3]
set yrange [0:10]
set grid
set arrow nohead from -10,0 to 10, 0 dt 3
set arrow nohead from 0,0 to 0, 10 dt 3

plot f1(x) with lines title "x^2", \
    f2(x) with lines title "x^4", \
    f3(x) with lines title "x^6", \
    f4(x) with lines title "x^8"    

pause -1
# EOF