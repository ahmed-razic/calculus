# power functions y = x**(2/(2k-1))

f1(x) = (11*x+2)/(2*x**3-1)

set xrange [-10:10]
set yrange [-10:10]
set sample 1000
set grid
set size ratio 1
set arrow nohead from -10,0 to 10, 0 dt 3
set arrow nohead from 0,-10 to 0, 10 dt 3

set arrow nohead from 1/2**(1.0/3),-10 to 1/2**(1.0/3), 10 dt 5

plot f1(x) with lines title "(11*x+2)/(2*x**3-1)"

pause -1

