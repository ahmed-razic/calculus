# power functions y = x**(2k-1)

f1(x) = x**(1.0/2)
f2(x) = x**(1.0/4)
f3(x) = x**(1.0/6)
f4(x) = x**(1.0/8)


set xrange [0:2]
set yrange [0:2]
set sample 2000
set grid
set size ratio 1
set arrow nohead from -10,0 to 10, 0 dt 3
set arrow nohead from 0,-10 to 0, 10 dt 3

plot f1(x) with lines title "x**(1.0/2)", \
    f2(x) with lines title "x**(1.0/4)", \
    f3(x) with lines title "x**(1.0/6)", \
    f4(x) with lines title "x**(1.0/8)"

pause -1
# EOF