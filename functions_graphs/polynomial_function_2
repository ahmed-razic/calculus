# power functions y = x**(2/(2k-1))

f1(x) = 8*x**4 -14*x**3 - 9*x**2 +11*x -1
f2(x) = (x-2)**4*(x+1)**3*(x-1)


set xrange [-3:3]
set yrange [-20:5]
set sample 500
set grid
set size ratio 1
set arrow nohead from -5,0 to 5, 0 dt 3
set arrow nohead from 0,-5 to 0, 5 dt 3

plot f1(x) with lines title "8*x**4 -14*x**3 - 9*x**2 +11*x -1", \
    f2(x) with lines title "(x-2)**4*(x+1)**3*(x-1)"

pause -1

