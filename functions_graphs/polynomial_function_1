# power functions y = x**(2/(2k-1))

f1(x) = x**3 + 6*(x**2) + 6*x + 1
f2(x) = x**2 + 2*x + 1


set xrange [-15:15]
set yrange [-15:15]
set sample 1500
set grid
set size ratio 1
set arrow nohead from -15,0 to 15, 0 dt 3
set arrow nohead from 0,-15 to 0, 15 dt 3

plot f1(x) with lines title "(x+1)^3", f2(x) with lines title "(x+1)^2"

pause -1

