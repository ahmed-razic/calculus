# power functions y = x**(-2k)

f0(x) = x**(-1)
f00(x) = x**(-1)
f1(x) = x**(-2)
f2(x) = x**(-4)
f3(x) = x**(-6)

set xrange [-2:2]
set yrange [-2:2]
set grid
set size ratio 1
set arrow nohead from -10,0 to 10, 0 dt 3
set arrow nohead from 0,-10 to 0, 10 dt 3

plot f0(x) with lines title "1/x", \
    f1(x) with lines title "x**-2", \
    f2(x) with lines title "x**-4", \
    f3(x) with lines title "x**-6"

pause -1
# EOF