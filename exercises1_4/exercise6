set terminal qt 0
f1(x) = exp(x);
f2(x) = exp(-x);

f3(x) = -exp(x);
f4(x) = -exp(-x);


set grid
set xrange [-2 : 2]
set size ratio 1
set arrow nohead from -2,0 to 2,0 dt 2
set arrow nohead from 0,-8 to 0,8 dt 2

plot f1(x) with lines lw 1 title "e^x", f2(x) with lines lw 1 title "e^-x", f3(x) with lines lw 3 title "-e^x", f4(x) with lines lw 3 title "-e^-x"

pause -1
#EOF
