set terminal qt 0
f1(x) = exp(2*x);
f2(x) = 1/(-exp(2*x));
f3(x) = 3/(1-exp(2*x));


set grid;
set ytics 1
set xrange [-3 : 3];
set yrange [-6 : 6];

set samples 2000;
set size ratio 1;
set arrow nohead from -3,0 to 3,0 dt 2;
set arrow nohead from 0,-6 to 0,6 dt 2;

plot    f1(x) with lines lw 1 title "exp(2*x)", f2(x) with lines lw 1 title "1/(-exp(2*x))", \
        f3(x) with lines lw 3 title "1/(1-exp(2*x))";

pause -1;
#EOF
