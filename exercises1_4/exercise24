set terminal qt 0
f1(x) = sqrt(x);
f2(x) = sqrt(1 + 3**(-x));


set grid;
set xrange [-3 : 3];
set yrange [-1 : 6];

set samples 2000;
set size ratio 1;
set arrow nohead from -3,0 to 3,0 dt 2;
set arrow nohead from 0,-1 to 0,6 dt 2;

plot f1(x) with lines lw 1 title "sqrt(x)", f2(x) with lines lw 1 title "sqrt(1 + 3**(-x))";

pause -1;
#EOF
