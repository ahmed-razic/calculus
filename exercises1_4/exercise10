set terminal qt 0
f1(x) = -1 - exp(x);
f2(x) = -1 - exp(-x);

set grid;
set xrange [-2 : 2];
set size ratio 1;
set arrow nohead from -2,0 to 2,0 dt 2;
set arrow nohead from 0,-9 to 0,-1 dt 2;

plot f1(x) with lines lw 1 title "-1 - exp(x)", f2(x) with lines lw 1 title "-1 - exp(-x)";

pause -1;
#EOF
