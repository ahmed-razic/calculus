set terminal qt 0;
f1(x) = cos(exp(-x));
f2(x) = cos(x);

set grid;
set xrange [-5 : 5];
set samples 2000;
set size ratio 1;
set arrow nohead from -2,0 to 2,0 dt 2;
set arrow nohead from 0,-9 to 0,-1 dt 2;

plot f1(x) with lines lw 1 title "cos(exp(-x))", f2(x) with lines lw 1 title "cos(x)";

pause -1;
#EOF
