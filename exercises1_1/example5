set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-5:5]
set yrange [-5:5]
set arrow nohead from -5,0 to 5,0 dashtype 7 lc "green"
set arrow nohead from 0, -5 to 0, 5 dashtype 7 lc "green"

plot (x < 0 ? -f3(-x) : f3(x)) with lines

