#Define a function
f1(x) = 2**x
f2(x) = 3**x
f3(x) = 5**x


set terminal qt 0
set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-2:3]
set yrange [-0.5:4.5]
set arrow nohead from -5,0 to 5,0 dashtype 7 lc "green"
set arrow nohead from 0, -5 to 0, 5 dashtype 7 lc "green"

plot f1(x) with lines title "2^x", f2(x) with lines title "3^x", f3(x) with lines title "5^x"

pause -1

#EOF
