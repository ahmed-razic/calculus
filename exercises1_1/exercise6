#Define a function
f(x) = 4/(3-x)

set terminal qt 0
set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-8:12]
set yrange [-10:10]
set arrow nohead from 3,-10 to 3,10 dashtype 7 lc "green"
set arrow nohead from -8,0 to 12,0 dashtype 7 lc "green"


plot f(x) with lines title "f(x)"

pause -1

#EOF
