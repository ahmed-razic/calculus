#Define a function
f(x) = x**(-3)

set terminal qt 0
set xlabel "x"
set ylabel "f(x) = 1/x"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-5:5]
set yrange [-5:5]
set arrow nohead from -5,0 to 5,0 dashtype 7 lc "green"
set arrow nohead from 0, -5 to 0, 5 dashtype 7 lc "green"

plot f(x) with lines

pause -1

#EOF
