#Define a function
f1(x) = 5 - 2*x
f2(x) = -x**2 -2*x + 1

set terminal qt 0
set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-6:6]
set yrange [-6:6]
set arrow nohead from -6,0 to 6,0 dashtype 7 lc "green"
set arrow nohead from 0,-6 to 0,6 dashtype 7 lc "green"


plot f1(x) with lines, f2(x) with lines

pause -1

#EOF
