#Define a function
f1(x) = x/abs(x)
f2(x) = 1/abs(x)

set terminal qt 0
set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-4:4]
set yrange [-4:4]
set arrow nohead from -6,0 to 6,0 dashtype 7 lc "green"
set arrow nohead from 0,-6 to 0,6 dashtype 7 lc "green"

plot f1(x) with lines


set terminal qt 1
set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-4:4]
set yrange [-4:4]
set arrow nohead from -6,0 to 6,0 dashtype 7 lc "green"
set arrow nohead from 0,-6 to 0,6 dashtype 7 lc "green"


plot f2(x) with lines

pause -1

