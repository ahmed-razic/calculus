#Define a function
f(x) = -4*sqrt(x)

set terminal qt 0
set xlabel "x"
set ylabel "f(x)"
set xtics 1
set ytics 1
set grid
set size ratio 1
set xrange [-10:10]
set yrange [-10:10]
#set arrow nohead from -10,0 to 10,0 dashtype 7 lc "green"
#set arrow nohead from 0,-10 to 0,10 dashtype 7 lc "green"

plot f(x) with lines

pause -1

