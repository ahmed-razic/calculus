#Define a function
f1(x) = (x + 3)/(4 - sqrt(x**2 - 9))

set terminal qt 0
set xlabel "x"
set ylabel "f(x)"
set xtics 10
set ytics 10
set grid
set size ratio 1
#set xrange [-4:4]
#set yrange [-4:4]
set arrow nohead from -10,0 to 10,0 dashtype 7 lc "green"
set arrow nohead from 0,-10 to 0,10 dashtype 7 lc "green"

plot f1(x) with lines

pause -1

#EOF
